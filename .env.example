# NETRA नेत्र — Environment Variables Template
# Copy to .env and fill in your values.
# .env is in .gitignore — never commit it.

# ── Ollama (AI Brain) ─────────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen:14b         # Options: qwen:14b, llama2, mistral, neural-chat

# ── Paths ─────────────────────────────────────────────────────────────────────
NETRA_HOME=~/.netra
NETRA_OUTPUT_DIR=~/.netra/data/scans
NETRA_TOOLS_DIR=~/.netra/tools/bin

# ── Optional: Threat Intel APIs ───────────────────────────────────────────────
SHODAN_API_KEY=
CENSYS_API_ID=
CENSYS_API_SECRET=

# ── Optional: Notifications ───────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
EMAIL_FROM=
EMAIL_TO=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
