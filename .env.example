# NETRA Environment Variables
# Copy this file to .env and fill in your values
# cp .env.example .env

# ── App ──────────────────────────────────────────────────────────────────────
# Environment: development, staging, production
NETRA_ENVIRONMENT=development

# Debug mode (disable in production)
NETRA_DEBUG=true

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
NETRA_LOG_LEVEL=INFO

# Log format: json, text
NETRA_LOG_FORMAT=json

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (development/CLI):
NETRA_DATABASE_URL=sqlite+aiosqlite:///./netra.db

# PostgreSQL (production):
# NETRA_DATABASE_URL=postgresql+asyncpg://netra:netra@localhost:5432/netra

# Database connection pool settings
NETRA_DB_POOL_SIZE=5
NETRA_DB_MAX_OVERFLOW=10

# ── Authentication ───────────────────────────────────────────────────────────
# JWT secret key - MUST be set in production!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
NETRA_JWT_SECRET_KEY=change-me-to-random-64-char-string

# JWT expiration in minutes
NETRA_JWT_EXPIRE_MINUTES=60

# Cookie security (set to true in production with HTTPS)
NETRA_COOKIE_SECURE=false
NETRA_COOKIE_SAMESITE=lax

# ── API ──────────────────────────────────────────────────────────────────────
# CORS origins (comma-separated)
NETRA_API_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate limiting
NETRA_RATE_LIMIT_ENABLED=true
NETRA_RATE_LIMIT_STORAGE_URL=redis://localhost:6379/2

# ── AI / LLM ─────────────────────────────────────────────────────────────────
# AI provider: anthropic, ollama, none
NETRA_AI_PROVIDER=none

# Anthropic (Claude) - for cloud-based AI
NETRA_ANTHROPIC_API_KEY=
NETRA_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Ollama - for local AI inference
NETRA_OLLAMA_BASE_URL=http://localhost:11434
NETRA_OLLAMA_MODEL=llama3.1:8b

# Token budget per scan (controls AI costs)
NETRA_AI_TOKEN_BUDGET_PER_SCAN=50000

# ── Celery (Distributed Tasks) ───────────────────────────────────────────────
# Redis broker for Celery
NETRA_CELERY_BROKER_URL=redis://localhost:6379/0
NETRA_CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Worker concurrency
NETRA_CELERY_WORKER_CONCURRENCY=4

# ── Notifications ────────────────────────────────────────────────────────────
# Slack webhook for scan notifications
NETRA_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK

# SMTP configuration for email notifications
NETRA_SMTP_HOST=smtp.example.com
NETRA_SMTP_PORT=587
NETRA_SMTP_USER=notifications@example.com
NETRA_SMTP_PASSWORD=your-app-password

# Email addresses
NETRA_NOTIFICATION_EMAIL_FROM=netra@example.com
NETRA_NOTIFICATION_EMAIL_TO=security-team@example.com

# ── External Tool API Keys ───────────────────────────────────────────────────
# Shodan (for vulnerability intelligence)
SHODAN_API_KEY=

# WPScan (for WordPress security scanning)
WPSCAN_API_TOKEN=

# ── Scanning ─────────────────────────────────────────────────────────────────
# Default scan profile: quick-recon, standard, full-pentest, custom
NETRA_DEFAULT_SCAN_PROFILE=standard

# Maximum concurrent scans
NETRA_MAX_CONCURRENT_SCANS=3

# Scan timeout in hours
NETRA_SCAN_TIMEOUT_HOURS=12

# ── Reports ──────────────────────────────────────────────────────────────────
# Directory for generated reports
NETRA_REPORTS_DIR=~/.netra/reports

# Directory for evidence files
NETRA_EVIDENCE_DIR=~/.netra/evidence

# ── Integrations ─────────────────────────────────────────────────────────────
# DefectDojo (for vulnerability management)
NETRA_DEFECTDOJO_URL=https://defectdojo.example.com
NETRA_DEFECTDOJO_API_KEY=your-api-key

# Jira (for ticket creation)
NETRA_JIRA_URL=https://your-domain.atlassian.net
NETRA_JIRA_EMAIL=your-email@example.com
NETRA_JIRA_API_TOKEN=your-api-token
NETRA_JIRA_PROJECT_KEY=SEC

# ── Docker ───────────────────────────────────────────────────────────────────
# Host for API server
NETRA_API_HOST=0.0.0.0

# Port for API server
NETRA_API_PORT=8000
